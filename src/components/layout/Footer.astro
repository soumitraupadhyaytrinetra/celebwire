---
import { siteConfig } from "../../config";
---

<footer class="border-t border-[var(--border)] mt-16">
  <div class="app-layout py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="col-span-2 md:col-span-1">
        <div class="text-lg font-bold gradient-text mb-3">{siteConfig.name}</div>
        <p class="text-sm text-[var(--text-tertiary)] leading-relaxed">{siteConfig.description}</p>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-wide uppercase text-[var(--text-tertiary)] mb-4">Regions</h4>
        <ul class="space-y-2">
          <li><a href="/hollywood" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">🎬 Hollywood</a></li>
          <li><a href="/bollywood" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">🇮🇳 Bollywood</a></li>
          <li><a href="/kpop" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">🎤 K-Pop</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-wide uppercase text-[var(--text-tertiary)] mb-4">More</h4>
        <ul class="space-y-2">
          <li><a href="/music" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">🎵 Music</a></li>
          <li><a href="/general" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">🌟 General</a></li>
          <li><a href="/trending" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Trending</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-[var(--border)] mt-10 pt-8 text-center text-xs text-[var(--text-tertiary)]">
      &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
    </div>
  </div>
</footer>
